
    <UserControl x:Class="Grudy.termToolEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Grudy" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="263.494" d:DesignWidth="532.169">
    <Grid Background="Black">
        <Menu Background="Transparent" Height="29" VerticalAlignment="Top" FontFamily="Roboto" FontSize="14" HorizontalContentAlignment="Center" Padding="0,5,0,0">
            <materialDesign:PackIcon Kind="Text" Height="16" Width="16" Foreground="#D8B6C6D1" />
            <Label Foreground="White" FontSize="10">Edit</Label>
            <MenuItem Background="Black" Foreground="CadetBlue" Header="Arquivo">
                <MenuItem  x:Name="mn_open"  Header="Abrir"  Click="MenuItem_Click"></MenuItem>
                <MenuItem x:Name="mn_save"  Header="Salvar" Click="MenuItem_Click"></MenuItem>
                <MenuItem x:Name="mn_save_as"  Header="Salvar Como" Click="MenuItem_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem x:Name="mn_exit"   Header="Sair" Click="MenuItem_Click"></MenuItem>
            </MenuItem>

            <MenuItem Background="Black" Foreground="CadetBlue" Header="Editar">
                <MenuItem  x:Name="mn_rdo"  Header="Desfazer"  Click="MenuItem_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem x:Name="mn_cut"  Header="Recortar" Click="MenuItem_Click"></MenuItem>
                <MenuItem x:Name="mncopy"  Header="Copiar" Click="MenuItem_Click"></MenuItem>                
                <MenuItem x:Name="mnpast"   Header="Colar" Click="MenuItem_Click"></MenuItem>
                <MenuItem x:Name="mnfind"   Header="Localizar" Click="MenuItem_Click"></MenuItem>
            </MenuItem>
            
            <MenuItem Background="Black" Foreground="CadetBlue" x:Name="mn_exit2"  Header="Sair"></MenuItem>
            <Label Foreground="White" FontSize="10" Content="{Binding  FileNameValid}"></Label>
        </Menu>
        <RichTextBox x:Name="editor" Padding="5,5,5,5" BorderThickness="0" BorderBrush="Transparent" Background="#FF282828" Foreground="White" FontFamily="Consolas" FontSize="14" Margin="0,29,0,0">
            <FlowDocument>
                <Paragraph>
                    <Run Text="RichTextBox"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>

    </Grid>
</UserControl>
